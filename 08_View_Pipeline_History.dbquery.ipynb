   "outputs": [],
   "source": [
    "SELECT *\n",
    "FROM audit.pipeline_execution_log\n",
    "ORDER BY start_time DESC;\n",
    "\n",
    "/* View Longest Running Pipeline */\n",
    "\n",
    "SELECT pipeline_name,\n",
    "       MAX(duration_seconds) AS longest_runtime\n",
    "FROM audit.pipeline_execution_log\n",
    "GROUP BY pipeline_name\n",
    "ORDER BY longest_runtime DESC;"
   ]
  }
